APP_ENV=production

GEMINI_API_KEY=your-gemini-api-key
PINECONE_API_KEY=your-pinecone-api-key

LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash-lite

EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768
EMBEDDING_BATCH_SIZE=32

PINECONE_INDEX=research-rag
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

PUBLIC_INGEST_ENABLED=false
REQUIRE_HCAPTCHA=true
HCAPTCHA_SECRET_KEY=your-hcaptcha-secret
HCAPTCHA_SITE_KEY=your-hcaptcha-site-key
QUERY_MAX_CHARS=600
QUERY_TOP_K_MAX=6
RATE_LIMIT_WINDOW_SECONDS=3600
RATE_LIMIT_REQUESTS_PER_WINDOW=10
DAILY_REQUEST_LIMIT=75
CACHE_TTL_SECONDS=21600
SESSION_SIGNING_SECRET=generate-a-long-random-secret

HYBRID_SEARCH_ENABLED=true
HYBRID_ALPHA=0.7
BM25_K=10

LEXICAL_INDEX_PATH=backend/data/lexical_index.jsonl
CORPUS_MANIFEST_PATH=data/corpus/ai_research_corpus.json

CORS_ORIGINS=["https://your-frontend-domain.pages.dev"]
